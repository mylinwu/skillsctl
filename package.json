{
  "name": "skillctl",
  "version": "0.1.0",
  "description": "Local Agent Skills management TUI.",
  "type": "module",
  "bin": {
    "skillctl": "./dist/bin.js"
  },
  "scripts": {
    "dev": "tsx src/bin.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "tsup src/bin.ts --format esm --dts --clean --splitting false --out-dir dist",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "yaml": "^2.8.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.21.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  },
  "files": [
    "dist"
  ]
}
